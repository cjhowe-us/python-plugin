{
  "version": 1,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-ruff.py", "timeout": 30 },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-mypy.py", "timeout": 60 },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-pytest.py", "timeout": 120 },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-test-required.py", "timeout": 5 },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse-uv-lock.py", "timeout": 30 }
        ]
      }
    ]
  }
}
